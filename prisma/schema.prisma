// Prisma schema - BD en snake_case (tablas y columnas).
// Ver /docs/conventions.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---- Better Auth (tablas mapeadas a snake_case) ----
// User roles stored in English: admin, carrier, collaborator, vendor, developer

enum UserRole {
  admin
  carrier
  collaborator
  vendor
  developer
}

enum TaskStatus {
  pending
  in_progress
  completed
}

model User {
  id            String         @id @default(cuid()) @map("id")
  name          String         @map("name")
  email         String         @unique @map("email")
  position      String?        @map("position")
  emailVerified Boolean        @map("email_verified")
  image         String?        @map("image")
  birthDate     DateTime?      @map("birth_date")
  role          UserRole       @default(collaborator) @map("role")
  canEditTarget Boolean        @default(true) @map("can_edit_target")
  canEditRoutes  Boolean        @default(false) @map("can_edit_routes")
  canAddRoutes   Boolean        @default(true) @map("can_add_routes")
  canViewMessages   Boolean       @default(false) @map("can_view_messages")
  canViewIdeas      Boolean       @default(false) @map("can_view_ideas")
  canViewRoutes     Boolean       @default(false) @map("can_view_routes")
  canViewRouteLogs  Boolean       @default(false) @map("can_view_route_logs")
  canViewUnitTypes  Boolean       @default(false) @map("can_view_unit_types")
  canViewQuotes     Boolean       @default(false) @map("can_view_quotes")
  canViewProviders  Boolean       @default(false) @map("can_view_providers")
  canViewClients    Boolean       @default(false) @map("can_view_clients")
  canViewEmployees  Boolean       @default(false) @map("can_view_employees")
  canViewVendors    Boolean       @default(false) @map("can_view_vendors")
  canViewLaptops    Boolean       @default(false) @map("can_view_laptops")
  canViewPhones     Boolean       @default(false) @map("can_view_phones")
  canViewEmails     Boolean       @default(false) @map("can_view_emails")
  canViewTasks      Boolean       @default(false) @map("can_view_tasks")
  canViewShipments  Boolean       @default(false) @map("can_view_shipments")
  canViewFinances   Boolean       @default(false) @map("can_view_finances")
  whatsappPhone  String?        @map("whatsapp_phone")
  createdAt     DateTime       @map("created_at")
  updatedAt     DateTime       @map("updated_at")
  sessions         Session[]
  accounts         Account[]
  profile          Profile?
  carrierRoutes    CarrierRoute[]
  carrierSuggestions CarrierSuggestion[]
  employeeProfile  EmployeeProfile?
  ownedCollaborators EmployeeProfile[] @relation("CollaboratorOwner")
  assignedLaptops  Laptop[]
  assignedPhones   Phone[]
  assignedEmails   EmailAccountUser[]
  ideas            Idea[]
  createdRoutes    Route[]        @relation("RouteCreatedBy")
  assignedTasks    Task[]         @relation("TaskAssignee")
  createdTasks     Task[]         @relation("TaskCreator")
  sentMessages     Message[]      @relation("SentMessages")
  carrierMessages  Message[]      @relation("CarrierMessages")
  notifications    Notification[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid()) @map("id")
  expiresAt DateTime @map("expires_at")
  token     String   @unique @map("token")
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid()) @map("id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @map("scope")
  password              String?   @map("password")
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("accounts")
}

model Verification {
  id         String    @id @default(cuid()) @map("id")
  identifier String   @map("identifier")
  value      String   @map("value")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verifications")
}

// ---- App: routes (admin CRUD), profiles (carrier extra data) ----

enum RouteStatus {
  active
  inactive
  pending
}

model UnitTypeDef {
  id        String   @id @default(cuid()) @map("id")
  name      String   @map("name")
  value     String   @unique @map("value")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("unit_types")
}

model IncidentTypeDef {
  id        String   @id @default(cuid()) @map("id")
  name      String   @map("name")
  value     String   @unique @map("value")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("incident_types")
}

model Route {
  id               String             @id @default(cuid()) @map("id")
  origin           String             @map("origin")
  destination      String             @map("destination")
  description      String?            @map("description")
  target           Float?             @map("target")
  weeklyVolume     Int?               @map("weekly_volume")
  destinationState String?            @map("destination_state")
  unitType         String             @default("caja_seca") @map("unit_type")
  status           RouteStatus        @default(pending) @map("status")
  createdById      String?            @map("created_by_id")
  createdBy        User?              @relation("RouteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  carrierRoutes    CarrierRoute[]
  clientRoutes     ClientRoute[]
  unitTargets      RouteUnitTarget[]

  @@map("routes")
}

model RouteUnitTarget {
  id       String  @id @default(cuid()) @map("id")
  routeId  String  @map("route_id")
  route    Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  unitType String  @map("unit_type")
  target   Float?  @map("target")

  @@unique([routeId, unitType])
  @@map("route_unit_targets")
}

model CarrierRoute {
  id            String   @id @default(cuid()) @map("id")
  carrierId            String   @map("carrier_id")
  routeId              String   @map("route_id")
  unitType             String   @default("") @map("unit_type")
  carrierTarget        Float?   @map("carrier_target")
  carrierWeeklyVolume  Int?     @map("carrier_weekly_volume")
  editUnlockRequested  Boolean  @default(false) @map("edit_unlock_requested")
  editUnlockApproved   Boolean  @default(false) @map("edit_unlock_approved")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  carrier       User     @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  route         Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([carrierId, routeId, unitType])
  @@map("carrier_routes")
}

enum ContactType {
  phone
  email
}

model Profile {
  id             String    @id @default(cuid()) @map("id")
  userId         String    @unique @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commercialName String?   @map("commercial_name")
  legalName      String?   @map("legal_name")
  rfc            String?   @map("rfc")
  address        String?   @map("address")
  contacts       Contact[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("profiles")
}

model Contact {
  id        String      @id @default(cuid()) @map("id")
  profileId String      @map("profile_id")
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      ContactType @map("type")
  value     String      @map("value")
  label     String?     @map("label")
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("contacts")
}

// ---- App: clientes (admin CRUD) ----

model Client {
  id        String   @id @default(cuid()) @map("id")
  name      String   @map("name")
  contactName String? @map("contact_name")
  position  String?  @map("position")
  legalName String?  @map("legal_name")
  rfc       String?  @map("rfc")
  email     String?  @map("email")
  phone     String?  @map("phone")
  address   String?  @map("address")
  notes     String?  @map("notes")
  detentionConditions String? @map("detention_conditions")
  productTypes String[] @default([]) @map("product_types")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  clientRoutes ClientRoute[]

  @@map("clients")
}

model ClientRoute {
  id           String   @id @default(cuid()) @map("id")
  clientId     String   @map("client_id")
  routeId      String   @map("route_id")
  target       Float?   @map("target")
  weeklyVolume Int?     @map("weekly_volume")
  createdAt    DateTime @default(now()) @map("created_at")
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  route        Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([clientId, routeId])
  @@map("client_routes")
}

// ---- App: log de cambios en rutas (solo admin) ----

model RouteLog {
  id         String   @id @default(cuid()) @map("id")
  routeId    String   @map("route_id")
  routeLabel String   @map("route_label")
  action     String   @map("action")
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  changes    String?  @map("changes")
  snapshot   String?  @map("snapshot")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([routeId])
  @@index([createdAt])
  @@map("route_logs")
}

// ---- App: auditoría global de cambios ----

model AuditLog {
  id            String   @id @default(cuid()) @map("id")
  resource      String   @map("resource")
  resourceId    String   @map("resource_id")
  resourceLabel String   @map("resource_label")
  action        String   @map("action")
  userId        String   @map("user_id")
  userName      String   @map("user_name")
  changes       String?  @map("changes")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---- App: mensajería interna (carrier ↔ compras/admin) ----

model Message {
  id         String   @id @default(cuid()) @map("id")
  carrierId  String   @map("carrier_id")
  senderId   String   @map("sender_id")
  senderName String   @map("sender_name")
  senderRole String   @map("sender_role")
  body       String   @map("body")
  createdAt  DateTime @default(now()) @map("created_at")
  carrier    User     @relation("CarrierMessages", fields: [carrierId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([carrierId, createdAt])
  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid()) @map("id")
  userId    String   @map("user_id")
  type      String   @map("type")
  title     String   @map("title")
  body      String?  @map("body")
  href      String?  @map("href")
  read      Boolean  @default(false) @map("read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ---- App: recursos internos (admin CRUD) ----

model EmployeeProfile {
  id         String  @id @default(cuid()) @map("id")
  userId     String  @unique @map("user_id")
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerUserId String? @map("owner_user_id")
  owner      User?   @relation("CollaboratorOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  position   String? @map("position")
  department String? @map("department")
  phone      String? @map("phone")
  password   String? @map("password")
  hireDate   DateTime? @map("hire_date")

  @@index([ownerUserId])
  @@map("employee_profiles")
}

model Laptop {
  id             String        @id @default(cuid()) @map("id")
  name           String        @map("name")
  password       String?       @map("password")
  serialNumber   String?       @map("serial_number")
  assignedToId   String?       @map("assigned_to_id")
  assignedTo     User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  emailAccountId String?       @map("email_account_id")
  emailAccount   EmailAccount? @relation("LaptopEmailAccount", fields: [emailAccountId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@map("laptops")
}

model Phone {
  id             String        @id @default(cuid()) @map("id")
  name           String        @map("name")
  phoneNumber    String?       @map("phone_number")
  password       String?       @map("password")
  imei           String?       @map("imei")
  assignedToId   String?       @map("assigned_to_id")
  assignedTo     User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  emailAccountId String?       @map("email_account_id")
  emailAccount   EmailAccount? @relation("PhoneEmailAccount", fields: [emailAccountId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@map("phones")
}

model EmailAccount {
  id        String             @id @default(cuid()) @map("id")
  type      String             @map("type")
  email     String             @map("email")
  password  String?            @map("password")
  assignees EmailAccountUser[]
  laptops   Laptop[]           @relation("LaptopEmailAccount")
  phones    Phone[]            @relation("PhoneEmailAccount")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@map("email_accounts")
}

model EmailAccountUser {
  emailAccountId String       @map("email_account_id")
  userId         String       @map("user_id")
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([emailAccountId, userId])
  @@map("email_account_users")
}

// ---- App: sugerencias de transportistas ----

model CarrierSuggestion {
  id          String   @id @default(cuid()) @map("id")
  title       String   @map("title")
  description String?  @map("description")
  status      String   @default("pending") @map("status")
  carrierId   String   @map("carrier_id")
  carrier     User     @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([carrierId])
  @@map("carrier_suggestions")
}

// ---- App: ideas (colaboradores + admins) ----

model Idea {
  id          String   @id @default(cuid()) @map("id")
  title       String   @map("title")
  description String?  @map("description")
  category    String?  @map("category")
  status      String   @default("pending") @map("status")
  authorId    String   @map("author_id")
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ideas")
}

model Image {
  id        String   @id @default(cuid()) @map("id")
  name      String   @map("name")
  url       String   @map("url")
  publicId  String   @unique @map("public_id")
  alt       String?  @map("alt")
  folder    String?  @map("folder")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("images")
}

model Setting {
  key   String @id @map("key")
  value String @map("value")

  @@map("settings")
}

// ---- App: tabla de embarques (admin CRUD) ----

enum ShipmentStatus {
  pending
  delivered
  delivered_with_delay
  not_delivered
  at_risk
  returned
}

model Shipment {
  id             String         @id @default(cuid()) @map("id")
  eco            String?        @map("eco")
  client         String?        @map("client")
  origin         String?        @map("origin")
  destination    String?        @map("destination")
  product        String?        @map("product")
  pickupDate     DateTime?      @map("pickup_date")
  deliveryDate   DateTime?      @map("delivery_date")
  legalName      String?        @map("legal_name")
  operatorName   String?        @map("operator_name")
  truck          String?        @map("truck")
  trailer        String?        @map("trailer")
  unit           String?        @map("unit")
  phone          String?        @map("phone")
  comments       String?        @map("comments")
  incident       String?        @map("incident")
  incidentType   String?        @map("incident_type")
  status         ShipmentStatus @default(pending) @map("status")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("shipments")
}

// ---- App: tabla de finanzas (admin CRUD) ----

model Finance {
  id             String    @id @default(cuid()) @map("id")
  eco            String?   @map("eco")
  client         String?   @map("client")
  origin         String?   @map("origin")
  destination    String?   @map("destination")
  sale           Float?    @map("sale")
  product        String?   @map("product")
  pickupDate     DateTime? @map("pickup_date")
  deliveryDate   DateTime? @map("delivery_date")
  legalName      String?   @map("legal_name")
  cost           Float?    @map("cost")
  operatorName   String?   @map("operator_name")
  truck          String?   @map("truck")
  trailer        String?   @map("trailer")
  unit           String?   @map("unit")
  phone          String?   @map("phone")
  comments       String?   @map("comments")
  incident       String?   @map("incident")
  incidentType   String?   @map("incident_type")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("finances")
}

// ---- App: tareas admin → developer ----

model Task {
  id          String     @id @default(cuid()) @map("id")
  title       String     @map("title")
  description String?    @map("description")
  status      TaskStatus @default(pending) @map("status")
  assigneeId  String     @map("assignee_id")
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdById String     @map("created_by_id")
  createdBy   User       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("tasks")
}
